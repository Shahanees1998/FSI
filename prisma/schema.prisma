// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                    @id @default(auto()) @map("_id") @db.ObjectId
  email                String                    @unique
  password             String
  firstName            String
  lastName             String
  phone                String?                   @unique
  role                 UserRole                  @default(AGENT)
  status               UserStatus                @default(INVITED)
  jobTitle             String?
  location             String?
  timezone             String?
  profileImage         String?
  profileImagePublicId String?
  emailVerified        Boolean                   @default(false)
  phoneVerified        Boolean                   @default(false)
  lastLogin            DateTime?
  resetToken           String?
  resetTokenExpiry     DateTime?
  isDeleted            Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  agentProfile                 AgentProfile?
  carrierProfile               CarrierProfile?
  notifications                Notification[]
  conversationsCreated         Conversation[]          @relation("ConversationCreatedBy")
  conversationParticipants     ConversationParticipant[]
  messagesSent                 ConversationMessage[]   @relation("ConversationMessageSender")
  requestedTickets             Ticket[]                @relation("TicketRequestedBy")
  assignedTickets              Ticket[]                @relation("TicketAssignedTo")
  ticketMessages               TicketMessage[]         @relation("TicketMessageAuthor")
  commissions                  CommissionRecord[]      @relation("CommissionAgent")
  commissionUpdates            CommissionRecord[]      @relation("CommissionUpdatedBy")
  insurerStatsAuthored         InsurerStat[]           @relation("InsurerStatUpdatedBy")
  announcements                Announcement[]          @relation("AnnouncementCreatedBy")
  adminLogs                    AdminLog[]              @relation("AdminActionBy")
  fcmTokens                    FcmToken[]
  clientProfiles               ClientProfile[]         @relation("ClientProfileAgent")
  policySubmissions            PolicySubmission[]      @relation("PolicySubmissionAgent")

  @@map("users")
}

model ClientProfile {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  agentId              String    @db.ObjectId
  firstName            String
  middleName           String?
  lastName             String
  preferredFirstName   String
  city                 String?
  state                String?
  country              String?   @default("USA")
  address              String?
  zipCode              String?
  email                String?
  phone                String?
  phoneType            String?
  sex                  String?
  birthDate            DateTime?
  profileImageUrl      String?
  spouseFirstName      String?
  spouseMiddleName     String?
  spouseLastName       String?
  spousePreferredFirstName String?
  spouseSex            String?
  spouseBirthDate      DateTime?
  /** Array of { firstName, middleName, lastName, preferredFirstName, sex, birthDate? } */
  childrenData         Json?
  notes                String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  agent User @relation("ClientProfileAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

enum PolicySubmissionStatus {
  DRAFT
  SUBMITTED
}

model PolicySubmission {
  id              String                 @id @default(auto()) @map("_id") @db.ObjectId
  agentId         String                 @db.ObjectId
  status          PolicySubmissionStatus @default(DRAFT)
  /** Derived 0–100 for list + wizard */
  progressPercent Int                    @default(0)
  /** Active wizard step 0–3: Applicant, Company, Client, Documents */
  currentStep     Int                    @default(0)
  /** Wizard payload (applicant, company, client, documents) */
  formData        Json                   @default("{}")
  /** For list/search (e.g. client name + product) */
  summaryLabel    String?
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  agent User @relation("PolicySubmissionAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@map("policy_submissions")
}

model Company {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  location   String?
  department String?
  address    String?
  city       String?
  state      String?
  country    String?
  phone      String?
  website    String?
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  agents AgentProfile[]

  @@map("companies")
}

model AgentProfile {
  id                    String      @id @default(auto()) @map("_id") @db.ObjectId
  userId                String      @unique @db.ObjectId
  companyId             String?     @db.ObjectId
  agentCode             String      @unique
  licenseNumber         String?
  /** FundServ / dealer code shown on the Contracting (My Contracts) carrier grid header when set. */
  fundServCode          String?
  agencyName            String?
  address               String?
  city                  String?
  state                 String?
  country               String?
  contractedAt          DateTime?
  preferredCarrierIds   String[]    @db.ObjectId
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("agent_profiles")
}

model CarrierProfile {
  id                   String          @id @default(auto()) @map("_id") @db.ObjectId
  userId               String          @unique @db.ObjectId
  carrierCode          String          @unique
  carrierName          String
  contactEmail         String?
  contactPhone         String?
  website              String?
  status               CarrierStatus   @default(ACTIVE)
  commissionRecords    CommissionRecord[]
  insurerStats         InsurerStat[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carrier_profiles")
}

model Conversation {
  id              String                    @id @default(auto()) @map("_id") @db.ObjectId
  subject         String
  type            ConversationType         @default(DIRECT)
  createdById     String                   @db.ObjectId
  lastMessageAt   DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  createdBy    User                      @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     ConversationMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String        @db.ObjectId
  userId         String        @db.ObjectId
  lastReadAt     DateTime?
  joinedAt       DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model ConversationMessage {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String               @db.ObjectId
  senderId       String               @db.ObjectId
  body           String
  messageType    PortalMessageType    @default(TEXT)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("ConversationMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("conversation_messages")
}

model Ticket {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  requesterId    String         @db.ObjectId
  assignedToId   String?        @db.ObjectId
  category       TicketCategory
  subject        String
  description    String
  status         TicketStatus   @default(OPEN)
  priority       Priority       @default(MEDIUM)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  requester User          @relation("TicketRequestedBy", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  messages   TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  ticketId    String     @db.ObjectId
  authorId    String     @db.ObjectId
  body        String
  internal    Boolean    @default(false)
  createdAt   DateTime   @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation("TicketMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model CommissionRecord {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  agentId           String            @db.ObjectId
  carrierProfileId  String            @db.ObjectId
  policyNumber      String
  clientName        String
  productLine       String
  amount            Float
  status            CommissionStatus  @default(PENDING)
  statementMonth    DateTime
  effectiveDate     DateTime?
  paidAt            DateTime?
  notes             String?
  updatedById       String?           @db.ObjectId
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  agent          User           @relation("CommissionAgent", fields: [agentId], references: [id], onDelete: Cascade)
  carrierProfile CarrierProfile @relation(fields: [carrierProfileId], references: [id], onDelete: Cascade)
  updatedBy      User?          @relation("CommissionUpdatedBy", fields: [updatedById], references: [id])

  @@map("commission_records")
}

model InsurerStat {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  carrierProfileId  String          @db.ObjectId
  metricMonth       DateTime
  activeAgents      Int             @default(0)
  submittedPolicies Int             @default(0)
  issuedPolicies    Int             @default(0)
  submittedPremium  Float           @default(0)
  issuedPremium     Float           @default(0)
  commissionsPaid   Float           @default(0)
  retentionRate     Float           @default(0)
  notes             String?
  updatedById       String?         @db.ObjectId
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  carrierProfile CarrierProfile @relation(fields: [carrierProfileId], references: [id], onDelete: Cascade)
  updatedBy      User?          @relation("InsurerStatUpdatedBy", fields: [updatedById], references: [id])

  @@unique([carrierProfileId, metricMonth])
  @@map("insurer_stats")
}

model Notification {
  id         String            @id @default(auto()) @map("_id") @db.ObjectId
  userId     String            @db.ObjectId
  title      String
  message    String
  type       NotificationType
  link       String?
  isRead     Boolean           @default(false)
  createdAt  DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Announcement {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  audience    AnnouncementAudience @default(ALL)
  createdById String              @db.ObjectId
  publishedAt DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy User @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model SystemSettings {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName             String
  siteDescription      String?
  supportEmail         String
  supportPhone         String?
  commissionDisclaimer String?
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("system_settings")
}

model FcmToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("fcm_tokens")
}

model AdminLog {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  adminId     String       @db.ObjectId
  action      AdminAction
  entityType  String
  entityId    String?
  description String
  metadata    String?
  createdAt   DateTime     @default(now())

  admin User @relation("AdminActionBy", fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

enum UserRole {
  ADMIN
  AGENT
  CARRIER
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CarrierStatus {
  ACTIVE
  PENDING
  ARCHIVED
}

enum ConversationType {
  DIRECT
  GROUP
  SUPPORT
}

enum PortalMessageType {
  TEXT
  SYSTEM
}

enum TicketCategory {
  GENERAL
  COMMISSION
  CARRIER
  TECHNICAL
  COMPLIANCE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_AGENT
  WAITING_ON_CARRIER
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  DISPUTED
}

enum NotificationType {
  SYSTEM
  MESSAGE
  COMMISSION
  TICKET
  ANNOUNCEMENT
}

enum AnnouncementAudience {
  ALL
  ADMINS
  AGENTS
  CARRIERS
}

enum AdminAction {
  USER_CREATED
  USER_UPDATED
  USER_STATUS_UPDATED
  COMMISSION_UPDATED
  TICKET_UPDATED
  INSURER_STAT_UPDATED
  SETTINGS_UPDATED
}