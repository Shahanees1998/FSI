# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=

# Database
DATABASE_URL=

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=

# Pusher (real-time)
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# FCM (Firebase Cloud Messaging) for mobile push notifications
# Option 1: JSON string of Firebase service account (from Firebase Console > Project Settings > Service accounts)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option 2: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/serviceAccountKey.json

# Learn — Experior Events (Eventcombo public listing URL; embedded on /agent/learn/.../experior-events)
# NEXT_PUBLIC_EXPERIOR_EVENTS_URL=https://www.eventcombo.com/...

# Learn — Experior Office Branches (embeds public corporate site; defaults to experiorfinancialgroup.com if unset)
# NEXT_PUBLIC_EXPERIOR_OFFICE_BRANCHES_URL=https://www.experiorfinancialgroup.com/...

# Learn — Life Insurance Products hub (“Access quoting tools” button)
# NEXT_PUBLIC_LIFE_QUOTING_TOOLS_URL=https://...

# Learn — Health Insurance Products hub (ACA “Get started” + sidebar link)
# NEXT_PUBLIC_NEW_HEALTH_PARTNERS_URL=https://...

# Learn — Health Insurance Products hub (Medicare “Get started” + sidebar link)
# NEXT_PUBLIC_C2G_HEALTH_URL=https://...

# Learn — Annuities/Quantum (Experior Advisor Portal — The Quantum Group)
# NEXT_PUBLIC_QUANTUM_ADVISOR_PORTAL_URL=https://...

# Learn — Global View Investment Platform (YouTube video IDs from the watch URL path)
# NEXT_PUBLIC_GLOBAL_VIEW_COMPENSATION_VIDEO_ID=
# NEXT_PUBLIC_GLOBAL_VIEW_TRIFECTA_RECRUITING_VIDEO_ID=

# Learn — News & Events (optional registration links)
# NEXT_PUBLIC_EXPERIOR_FACTOR_TICKETS_URL=https://...
# NEXT_PUBLIC_ENTREPRENEURS_LOUNGE_REGISTER_URL=https://...

# Learn — Marketing Hub (Growth & earnings roadmap buttons; convention also uses FACTOR tickets URL above)
# NEXT_PUBLIC_MARKETING_PROMOTIONS_COMPENSATION_GUIDE_URL=https://...
# NEXT_PUBLIC_MARKETING_PROMOTION_TRACK_URL=https://...

# Learn — My CRM (Experior CRM handoff; opens in a new tab when user confirms)
# NEXT_PUBLIC_EXPERIOR_CRM_URL=https://...

# Learn — Experior Connect / Workvivo (defaults to experiorfinancial.workvivo.us/login if unset)
# NEXT_PUBLIC_EXPERIOR_WORKVIVO_URL=https://experiorfinancial.workvivo.us/login
# Optional: official Workvivo mobile app store links (defaults to public Workvivo listings)
# NEXT_PUBLIC_EXPERIOR_WORKVIVO_IOS_URL=https://apps.apple.com/...
# NEXT_PUBLIC_EXPERIOR_WORKVIVO_ANDROID_URL=https://play.google.com/store/...
# Learn — Workvivo Getting Started page (optional Spaces screenshot under public/, then set path)
# NEXT_PUBLIC_WORKVIVO_DASHBOARD_IMAGE_SRC=/images/learn/workvivo-spaces.png
# YouTube video IDs only (from watch URL), for embedded tutorials on Getting Started
# NEXT_PUBLIC_WORKVIVO_PROFILE_TUTORIAL_YOUTUBE_ID=
# NEXT_PUBLIC_WORKVIVO_CREATE_POST_TUTORIAL_YOUTUBE_ID=

# Scoreboard → Training (YouTube embed: “Investments Paid Amount Filter”)
# NEXT_PUBLIC_SCOREBOARD_TRAINING_INVESTMENTS_PAID_FILTER_VIDEO_ID=
